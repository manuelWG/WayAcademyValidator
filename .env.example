# Neon PostgreSQL — connection string for the Neon branch named "dev"
# Never commit real credentials. .env is gitignored.
DATABASE_URL=

# Session encryption secret for nuxt-auth-utils (min 32 characters)
# Required for local auth. Do not reuse CI placeholder values in production.
NUXT_SESSION_PASSWORD=

# Optional: only for one-shot non-interactive create-admin automation.
# Do not treat these as persistent app config.
# ADMIN_USERNAME=
# ADMIN_DISPLAY_NAME=
# ADMIN_PASSWORD=

# Optional: explicit URL for npm run test:integration (never falls back to DATABASE_URL)
# DATABASE_URL_TEST=
