# Neon PostgreSQL — connection string for the Neon branch named "dev"
# Never commit real credentials. .env is gitignored.
DATABASE_URL=

# Session encryption secret for nuxt-auth-utils (min 32 characters)
# Required for local auth. Do not reuse CI placeholder values in production.
NUXT_SESSION_PASSWORD=

# Optional: explicit URL for npm run test:integration (never falls back to DATABASE_URL)
# DATABASE_URL_TEST=

# Document protection (server-only; validated lazily when crypto is used).
# Not required for build/tests. Never commit real values.
# 32-byte key encoded as canonical base64.
DOCUMENT_ENCRYPTION_KEY=
# Active key version: decimal integer in 1..2147483647 (PostgreSQL integer range).
DOCUMENT_ENCRYPTION_KEY_VERSION=
# 32-byte key encoded as canonical base64; MUST differ from DOCUMENT_ENCRYPTION_KEY.
DOCUMENT_LOOKUP_HMAC_KEY=
